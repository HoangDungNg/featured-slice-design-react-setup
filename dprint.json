{
  "lineWidth": 100,
  "indentWidth": 2,
  "useTabs": false,
  "excludes": [
    "**/node_modules",
    "**/dist",
    "**/coverage",
    "**/routeTree.gen.ts",
    "**/*-lock.json"
  ],
  "typescript": {
    "semiColons": "asi",
    "quoteStyle": "preferSingle",
    "jsx.quoteStyle": "preferDouble",
    "quoteProps": "asNeeded",
    "trailingCommas": "onlyMultiLine",
    "bracePosition": "sameLine",
    "nextControlFlowPosition": "sameLine",
    "binaryExpression.linePerExpression": false,
    "singleBodyPosition": "sameLineUnlessHanging",
    "memberExpression.linePerExpression": false,
    "typeLiteral.separatorKind.singleLine": "comma",
    "typeLiteral.separatorKind.multiLine": "semiColon",
    "jsx.multiLineParens": "prefer",
    "jsx.forceNewLinesSurroundingContent": false,
    "jsx.bracketPosition": "nextLine",
    "exportDeclaration.forceMultiLine": false
  },
  "json": {
  },
  "markdown": {
    "lineWidth": 100,
    "textWrap": "always"
  },
  "toml": {
  },
  "oxc": {
  },
  "malva": {
  },
  "markup": {
  },
  "yaml": {
  },
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.95.15.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.21.1.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/oxc-0.16.0.wasm",
    "https://plugins.dprint.dev/g-plane/malva-v0.15.2.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
  ]
}
